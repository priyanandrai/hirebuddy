enum Role {
  USER
  HELPER
}

enum TaskStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  INITIATED
  COMPLETED
  FAILED
  REFUNDED
}

enum MessageType {
  TEXT
  IMAGE
  OFFER
}

// ===== MESSAGE MODEL =====
model Message {
  id        String   @id @default(uuid())
  taskId    String
  senderId  String
  receiverId String
  
  message   String?
  type      MessageType @default(TEXT)
  mediaUrl  String?
  
  isRead    Boolean  @default(false)
  readAt    DateTime?

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  sender    User     @relation("SenderMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver  User     @relation("ReceiverMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  
  @@index([taskId])
  @@index([senderId])
  @@index([receiverId])
}

// ===== REVIEW & RATING MODEL =====
model Review {
  id        String   @id @default(uuid())
  taskId    String
  
  givenById String
  givenToId String
  
  rating    Int      // 1-5 stars
  comment   String?
  
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  givenBy   User     @relation("ReviewsGiven", fields: [givenById], references: [id], onDelete: Cascade)
  givenTo   User     @relation("ReviewsReceived", fields: [givenToId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  
  @@unique([taskId, givenById])
  @@index([givenToId])
}

// ===== PAYMENT MODEL (RAZORPAY) =====
model Payment {
  id        String   @id @default(uuid())
  taskId    String
  
  payerId   String
  payeeId   String
  
  amount    Int      // in paise
  currency  String   @default("INR")
  
  // Razorpay fields
  razorpayOrderId String?
  razorpayPaymentId String?
  razorpaySignature String?
  
  status    PaymentStatus @default(PENDING)
  method    String   @default("razorpay")
  
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  payer     User     @relation("PayerPayments", fields: [payerId], references: [id], onDelete: Cascade)
  payee     User     @relation("PayeePayments", fields: [payeeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  completedAt DateTime?
  
  @@index([taskId])
  @@index([payerId])
  @@index([payeeId])
}

// ===== NOTIFICATION MODEL =====
model Notification {
  id        String   @id @default(uuid())
  taskId    String
  
  senderId  String
  receiverId String
  
  type      String   // "task_accepted", "task_completed", "payment_received", etc.
  title     String
  message   String?
  
  isRead    Boolean  @default(false)
  readAt    DateTime?

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  sender    User     @relation("SentNotifications", fields: [senderId], references: [id], onDelete: Cascade)
  receiver  User     @relation("ReceivedNotifications", fields: [receiverId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  
  @@index([taskId])
  @@index([receiverId])
}
